pipeline {
    agent any
    stages {
        stage('build'){
            steps{
                echo 'Build stage started'
            }
        }
         stage('Deploy'){
            steps{
                echo 'Deploy stage started'
                sh 'echo Hello jenkins'
            }
         }
    }
